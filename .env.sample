# OpenAI API key (required)
OPENAI_API_KEY=sk-your-key-here

# Zendesk Help Center base URL for the docs being cloned
ZENDESK_BASE_URL=https://support.optisigns.com

# Locale used by the Zendesk Help Center API
ZENDESK_LOCALE=en-us

# Max number of articles to pull per run (assignment requires >= 30;
# support.optisigns.com has 404 published en-us articles total)
ARTICLE_LIMIT=50

# Existing vector store to reuse. Leave blank on first run —
# main.py will create one and print the ID to put here for next time.
VECTOR_STORE_ID=

# Name used when creating a new vector store
VECTOR_STORE_NAME=OptiBot Knowledge Base

# Where scraped Markdown files are written
ARTICLES_DIR=./articles

# Where delta-detection state (hashes, file IDs) is persisted between runs.
# Only used when DATABASE_URL is unset. Mount this path to a persistent
# volume if running this way in production.
STATE_FILE=./data/state.json

# Postgres connection string. When set, article state + full ADDED/
# UPDATED/REMOVED history is stored here instead of STATE_FILE — required
# for the AWS-deployed daily job, since an ECS Fargate task's filesystem
# doesn't persist between runs. Leave unset for local/grader runs.
#
# Backed by Supabase (project ref skqdzpufzlnypzrmqmkz, ap-south-1). Uses
# the Supavisor SESSION pooler (port 5432) rather than a direct connection,
# since direct connections are IPv6-only on Supabase's shared infra and
# ECS Fargate tasks get IPv4 addresses by default; session mode also
# supports prepared statements, which psycopg uses.
# Get the exact pooler host from `supabase status` / the Dashboard's
# connection string — the shard number (aws-0, aws-1, ...) is
# project-specific and using the wrong one fails with a cryptic
# "tenant/user not found" error rather than a clear "wrong host".
# postgresql://postgres.skqdzpufzlnypzrmqmkz:[YOUR-DB-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
